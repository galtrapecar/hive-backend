model Order {
    id                  Int             @id @default(autoincrement())
    organizationId      String
    customer            String
    price               Int
    weight              Int
    pickupPoint         String
    pickupLat           Float?
    pickupLng           Float?
    pickupTime          DateTime
    dropoffPoint        String
    dropoffLat          Float?
    dropoffLng          Float?
    dropoffTime         DateTime
    description         String?
    plan                Plan?

    createdAt           DateTime        @default(now())
    updatedAt           DateTime        @updatedAt
}
